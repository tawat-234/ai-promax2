from flask import Flask, request, jsonify
from flask_cors import CORS
import subprocess
import threading

app = Flask(__name__)

CORS(app)

lock = threading.Lock()


VOICE = "/home/sraangsilp/piper/en_US-lessac-medium.onnx"


def speak_text(text):

    with lock:

        command = [
    "/home/sraangsilp/Desktop/pro_max/venv/bin/piper",
    "--model",
    VOICE,
    "--output_file",
    "/tmp/output.wav"
]

        process = subprocess.Popen(
            command,
            stdin=subprocess.PIPE,
            text=True
        )

        process.communicate(text)

        subprocess.run([
            "aplay",
            "/tmp/output.wav"
        ])


@app.route("/speak", methods=["POST"])
def speak():

    print("POST received")

    data = request.json
    print(data)

    msg = data["message"]

    if msg == "sardine":

        print("Speaking sardine")

        speak_text(
            "This is Sardine. "
            "The main nutrient is protein and vitamins. "
            "Vitamin B twelve improves your brain health, "
            "red blood cells, and gives energy. "
            "Omega three gives you a healthy heart "
            "and reduces inflammation."
        )

        print("Finished")

        return jsonify({
            "status":"finished"
        })


    return jsonify({
        "status":"unknown"
    })


if __name__ == "__main__":
    app.run(debug=False)
