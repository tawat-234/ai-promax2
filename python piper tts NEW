from flask import Flask, request, jsonify
from flask_cors import CORS
from piper import PiperVoice
import subprocess
import threading
import wave


app = Flask(__name__)

CORS(app)

lock = threading.Lock()


# Piper voice model
VOICE = "/home/sraangsilp/piper/en_US-amy-medium.onnx"


# Load Piper ONCE when Flask starts
print("Loading Piper voice...")

voice = PiperVoice.load(VOICE)

print("Piper voice loaded!")


def speak_text(text):

    with lock:

        try:

            print("Generating speech...")

            output_file = "/tmp/output.wav"


            # Generate wav file
            with wave.open(output_file, "wb") as wav_file:

                voice.synthesize_wav(
                    text,
                    wav_file,
                )


            print("Playing audio...")


            subprocess.run([
                "aplay",
                output_file
            ])


            print("Audio finished")


        except Exception as e:

            print("Speech error:")
            print(e)



@app.route("/speak", methods=["POST"])
def speak():

    print("POST received")


    data = request.json

    print(data)


    msg = data["message"]


    if msg == "sardine":


        print("Speaking sardine")

        speak_text(
            "This is Sardine. The main nutrient is protein and vitamins. Vitamin B twelve improves your brain health, red blood cells, and gives energy. Omega three gives you a healthy heart and reduces inflammation."
        )

        print("Finished")


        return jsonify({
            "status":"finished"
        })


    return jsonify({
        "status":"unknown"
    })



if __name__ == "__main__":

    app.run(
        host="0.0.0.0",
        port=5000,
        debug=False
    )
